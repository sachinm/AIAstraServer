generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Auth {
  id                   String                 @id @default(dbgenerated("(uuid_generate_v4())::text"))
  username             String
  password             String
  date_of_birth        String
  place_of_birth       String?
  time_of_birth        String?
  email                String
  gender               String?
  is_active            Boolean?               @default(true)
  kundli_added         Boolean?               @default(false)
  role                 String?                @default("user")
  created_at           DateTime               @default(now()) @map("created_at")
  /// Client IP at account creation (from proxy headers when present).
  signup_ip            String?                @map("signup_ip")
  /// Bcrypt hash of the current magic-link code (plain code is only sent by email).
  magic_link_code_hash String?                @map("magic_link_code_hash")
  magic_link_expires_at DateTime?             @map("magic_link_expires_at") @db.Timestamptz(6)
  chats                Chat[]
  kundlis              Kundli[]
  userGeneratedContent UserGeneratedContent[]

  @@map("auth")
}

model Kundli {
  id                 String                 @id @default(dbgenerated("(uuid_generate_v4())::text"))
  user_id            String
  biodata            Json?
  d1                 Json?
  d7                 Json?
  d9                 Json?
  d10                Json?
  charakaraka        Json?
  vimsottari_dasa    Json?                  @map("vimsottari_dasa")
  narayana_dasa      Json?                  @map("narayana_dasa")
  other_readings     Json?                  @map("other_readings")
  created_at         DateTime               @default(now()) @db.Timestamptz(6)
  queue_status       String                 @default("pending") @map("queue_status")
  queue_started_at   DateTime?              @map("queue_started_at")
  queue_completed_at DateTime?              @map("queue_completed_at")
  last_sync_error    String?                @map("last_sync_error")
  user               Auth                   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  content            UserGeneratedContent[]

  @@index([user_id], map: "idx_kundlis_user_id")
  @@map("kundlis")
}

model SystemPrompt {
  id        String   @id @default(dbgenerated("(uuid_generate_v4())::text"))
  name      String   @unique
  prompt    String
  is_active Boolean? @default(true) @map("is_active")

  @@map("system_prompts")
}

model UserGeneratedContent {
  id         String   @id @default(dbgenerated("(uuid_generate_v4())::text"))
  user_id    String
  kundli_id  String
  remedies   Json?
  mantras    Json?
  routines   Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  kundli     Kundli   @relation(fields: [kundli_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       Auth     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([kundli_id], map: "idx_user_generated_content_kundli_id")
  @@index([user_id], map: "idx_user_generated_content_user_id")
  @@map("user_generated_content")
}

model Chat {
  id         String    @id @default(dbgenerated("(uuid_generate_v4())::text"))
  user_id    String
  name       String?
  is_active  Boolean   @default(true) @map("is_active")
  created_at DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       Auth      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages   Message[]
  chatLogs   ChatLog[]

  @@index([user_id], map: "idx_chats_user_id")
  @@map("chats")
}

model Message {
  id         String   @id @default(dbgenerated("(uuid_generate_v4())::text"))
  chat_id    String
  question   String
  ai_answer  String   @map("ai_answer")
  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  chat       Chat     @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chatLog    ChatLog?

  @@index([chat_id], map: "idx_messages_chat_id")
  @@map("messages")
}

model ChatLog {
  id                 String   @id @default(dbgenerated("(uuid_generate_v4())::text"))
  chat_id            String   @map("chat_id")
  message_id         String   @unique @map("message_id")
  request_payload    Json     @map("request_payload")
  response_payload   Json     @map("response_payload")
  /// True when the answer was delivered via POST /api/chat/ask-stream (SSE). False for GraphQL `ask`.
  /// Matches the web app when VITE_CHAT_STREAM is enabled (default); not sent from the client—set by the server.
  client_delivery_sse Boolean @default(false) @map("client_delivery_sse")
  created_at         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  chat               Chat     @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  message            Message  @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([chat_id], map: "idx_chat_logs_chat_id")
  @@map("chat_logs")
}
