# Database – Supabase Postgres (backend only; never expose to frontend)
# Pooler URL for Prisma Client at runtime
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL for migrations
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# JWT secret for session tokens (required; min 32 chars, use a long random string)
JWT_SECRET=your-jwt-secret-min-32-chars

# Supabase (optional – only if keeping any Supabase client temporarily)
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=

# Optional: PII encryption at rest (32 bytes hex or base64). If set, DOB/POB/TOB are encrypted in auth.
# ENCRYPTION_KEY=

# Superadmin – default login that is always available.
# Set SUPERADMIN_PASSWORD (min 16 chars) to enable. Run backend with npm start to create/update the account.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=AdAstra_Sup3r@dmin_#2024!Xk9
SUPERADMIN_EMAIL=superadmin@adastra.local

# Optional: OpenAI / LLM (for RAG/query)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# Groq – used for chat with Vedic astrology oracle (model: openai/gpt-oss-120b)
GROQ_API_KEY=
# Optional override for Groq model id
# MODEL_ID=openai/gpt-oss-120b

# GraphQL `ask` chat backend: groq (default) or gemini
# CHAT_LLM_PROVIDER=groq
# Google Gemini (required when CHAT_LLM_PROVIDER=gemini)
# GEMINI_API_KEY=
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
# GEMINI_FLASH_MODEL_ID=gemini-2.5-flash
# Max output tokens per chat reply (256–65536; default 8192). Raise if answers truncate.
# GEMINI_MAX_OUTPUT_TOKENS=16384
# Node fetch (undici) defaults to ~300s per phase; slow Gemini replies need more. Default 600000 (10m). 0 = no limit.
# GEMINI_HTTP_TIMEOUT_MS=600000
# Optional overrides (undici headersTimeout / bodyTimeout):
# GEMINI_FETCH_HEADERS_TIMEOUT_MS=
# GEMINI_FETCH_BODY_TIMEOUT_MS=

# Transactional email — magic link sign-in (8-char code, 5 min). Use Resend and/or SMTP.
# RESEND_API_KEY=
# MAIL_FROM="AdAstra <noreply@yourdomain.com>"
# Optional subject override:
# MAGIC_LINK_EMAIL_SUBJECT=Your sign-in code
# Or SMTP (if not using Resend):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=

# Google reCAPTCHA v3 (secret key for siteverify). When set, login and signup require a valid token from the web app.
# Create keys: https://www.google.com/recaptcha/admin (v3). Frontend: VITE_RECAPTCHA_SITE_KEY (same registration).
# RECAPTCHA_SECRET_KEY=
# Optional v3 score threshold 0–1 (default 0.5). Ignored for v2 checkbox keys.
# RECAPTCHA_MIN_SCORE=0.5

# Optional: server port (default 3000)
# PORT=3000
# Authenticated chat token streaming (same JWT as GraphQL). Frontend: VITE_CHAT_STREAM (default on).
# POST /api/chat/ask-stream — proxy must not buffer SSE (nginx: proxy_buffering off; X-Accel-Buffering: off is set).
# Optional: SSE comment ping interval (ms) during long LLM wait; default 12000, clamped 5000–60000.
# CHAT_SSE_PING_MS=12000
# DB: chat_logs.client_delivery_sse — true for /api/chat/ask-stream, false for GraphQL ask (matches VITE_CHAT_STREAM when client default). See docs/chat-sse-deployment.md.

# AstroKundli 3rd party API – base URL per environment (used by queue worker)
# Local/dev: port 8765; Staging: 8766; Production: 8767
ASTROKUNDLI_BASE_URL_LOCAL=http://localhost:8765
ASTROKUNDLI_BASE_URL_STAGING=http://localhost:8766
ASTROKUNDLI_BASE_URL_PROD=http://localhost:8767
# Optional: API key if the 3rd party requires it
# ASTROKUNDLI_API_KEY=

# Optional: set ASTROKUNDLI_LOG_RESPONSE=1 to log API responses to kundli-queue.log (for debugging)
# ASTROKUNDLI_LOG_RESPONSE=1

# Kundli queue worker – interval in ms (default 30000 = 30s)
# KUNDLI_QUEUE_INTERVAL_MS=30000

# Kundli queue log file – path for queue task logs (default: logs/kundli-queue.log)
# KUNDLI_QUEUE_LOG_FILE=logs/kundli-queue.log
# Set KUNDLI_QUEUE_LOG_CONSOLE=1 to also log to stdout
